@page "/admin/pos"

<PageTitle>POS</PageTitle>

<RadzenFormField Text="Search Products" Style="width: 100%;">
    <RadzenTextBox Style="width: 100%;" Change="FilterProducts" />
</RadzenFormField>
@if (products.Count() > 0)
{
    <RadzenRow AlignItems="AlignItems.Start" JustifyContent="JustifyContent.Start" Gap="1rem" Class="rz-py-sm-4">
        @foreach (var product in products)
        {
            <RadzenColumn>
                <RadzenCard Class="rz-my-12 rz-mx-auto" Style="width: 420px">
                    <RadzenImage Path="@product?.images[0].short_path" Style="width: 100%; height: 200px; object-fit: cover;" />
                    <RadzenText Style="margin: 10px 0; font-size: 20px; font-weight: bold;">@product.product_name</RadzenText>
                    <RadzenText>Rs. @product.regular_price</RadzenText>
                    <RadzenStack style="margin-top: 10px;" Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                        <RadzenButton Click="@(() => AddToCart(product))">Add To Cart</RadzenButton>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
        }
    </RadzenRow>
}
